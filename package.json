{
  "name": "weasyprint-wrapper",
  "version": "1.0.0",
  "description": "Node.js wrapper around the WeasyPrint CLI",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs",
      "default": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "index.js",
    "Readme.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "npm run lint && npm run format:check && npm test",
    "pack:check": "npm run build && node scripts/verify-pack.js",
    "prepare": "node scripts/install-hooks.js",
    "prepack": "npm run build",
    "test": "npm run build && node test/index.test.js && node test/esm.test.mjs",
    "test:real": "npm run build && node scripts/real-world-smoke.js",
    "smoke:pdf": "npm run build && node scripts/generate-test-pdf.js"
  },
  "keywords": [
    "weasyprint",
    "pdf",
    "htmltopdf",
    "wrapper",
    "cli-wrapper",
    "weasyprint-pdf",
    "pdf-generator"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dills122/weasyprint-wrapper.git"
  },
  "bugs": {
    "url": "https://github.com/dills122/weasyprint-wrapper/issues"
  },
  "homepage": "https://github.com/dills122/weasyprint-wrapper#readme",
  "author": "Dylan Steele",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^8.57.1",
    "lefthook": "^1.11.14",
    "prettier": "^3.6.2"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
