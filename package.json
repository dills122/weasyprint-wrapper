{
  "name": "weasyprint-wrapper",
  "version": "0.1.3",
  "description": "Node.js wrapper around the WeasyPrint CLI",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs",
      "default": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "index.js",
    "Readme.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "prepack": "npm run build",
    "test": "npm run build && node test/index.test.js && node test/esm.test.mjs",
    "test:real": "npm run build && node scripts/real-world-smoke.js",
    "smoke:pdf": "npm run build && node scripts/generate-test-pdf.js"
  },
  "keywords": [
    "weasyprint",
    "pdf",
    "htmltopdf",
    "wrapper",
    "cli-wrapper",
    "weasyprint-pdf",
    "pdf-generator"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dills122/weasyprint-wrapper.git"
  },
  "bugs": {
    "url": "https://github.com/dills122/weasyprint-wrapper/issues"
  },
  "homepage": "https://github.com/dills122/weasyprint-wrapper#readme",
  "author": "Dylan Steele",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  }
}
